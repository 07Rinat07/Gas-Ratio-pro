  "methods": [
    {
      "method_id": "petrophysics.vsh_gr_linear",
      "name": "Linear gamma-ray shale volume",
      "category": "shale_volume",
      "implementation": "las_editor.petrophysical_workspace.calculate_shale_volume",
      "formula": "I_GR=(GR-GR_clean)/(GR_shale-GR_clean); Vsh=clip(I_GR,0,1)",
      "status": "project_engineering_hint",
      "report_policy": "allowed_with_warning",
      "provenance": {
        "source_id": "project.vsh.linear",
        "title": "Project transparent linear gamma-ray normalization",
        "authors": [
          "GAS RATIO PRO project"
        ],
        "year": "2026",
        "source_type": "internal_project_engine",
        "legal_status": "bibliographic_metadata_and_short_equation_only",
        "citation_note": "Use the bibliographic record and original project implementation; do not reproduce protected figures or tables."
      },
      "inputs": [
        {
          "name": "GR",
          "unit": "gAPI",
          "domain": "finite"
        }
      ],
      "parameters": [
        {
          "name": "gr_clean",
          "unit": "gAPI",
          "domain": "gr_clean < gr_shale"
        },
        {
          "name": "gr_shale",
          "unit": "gAPI",
          "domain": "gr_shale > gr_clean"
        }
      ],
      "output": {
        "name": "VSH",
        "unit": "fraction",
        "domain": "0..1"
      },
      "applicability": "First-pass shale-volume normalization between locally selected clean and shale endpoints.",
      "limitations": "Endpoint selection is field-specific; linear response is not a universal geological model.",
      "validation": {
        "dataset_ids": [
          "vsh_gr_linear_reference"
        ],
        "absolute_tolerance": 1e-10,
        "relative_tolerance": 1e-09,
        "uncertainty": {
          "kind": "deterministic_contract_only",
          "note": "Parameter and input-data uncertainty is not estimated by this deterministic foundation gate."
        }
      }
    },
